#!/bin/bash
# Pre-commit hook: verify story and profile citations against the DB.
# Runs scripts/verify-stories.js when stories.js or people.js is staged.
# Blocks the commit on any error. Reporter only — no auto-fix.

set -e

CHANGED=$(git diff --cached --name-only | grep -E '^web/lib/(stories|people)\.js$' || true)

if [ -n "$CHANGED" ]; then
    echo "Running story verification..."
    node scripts/verify-stories.js
fi
